
@{
    ViewBag.Title = "ThemTopping";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}
<h2>Thêm Topping Mới</h2>

<div class="container">
    <div class="controls">
        <button class="btn btn-primary" onclick="window.location.href='Topping'">
            <i class="fas fa-arrow-left"></i> Quay lại danh sách Topping
        </button>
    </div>

    <form id="add-topping-form">
        <div class="form-group">
            <label for="topping-name">Tên Topping</label>
            <input type="text" id="topping-name" name="topping-name" required>
        </div>
        <div class="form-group">
            <label for="topping-price">Giá</label>
            <input type="number" id="topping-price" name="topping-price" required>
        </div>
        <div class="form-group">
            <label for="topping-status">Trạng thái</label>
            <select id="topping-status" name="topping-status" required>
                <option value="Còn hàng">Còn hàng</option>
                <option value="Hết hàng">Hết hàng</option>
            </select>
        </div>
        <div class="form-group">
            <label for="topping-quantity">Số lượng</label>
            <input type="number" id="topping-quantity" name="topping-quantity" required>
        </div>
        <button type="submit" class="btn btn-primary">Thêm Topping</button>
    </form>
</div>

