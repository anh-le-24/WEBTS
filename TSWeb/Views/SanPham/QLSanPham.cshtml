@{
    ViewBag.Title = "SanPham";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="container">
    <a href="~/SanPham/ThemSanPham" type="button" class="button ">
        <span class="button__text">Thêm </span>
        <span class="button__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" viewBox="0 0 24 24" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" stroke="currentColor" height="24" fill="none" class="svg"><line y2="19" y1="5" x2="12" x1="12"></line><line y2="12" y1="12" x2="19" x1="5"></line></svg></span>
    </a>
</div>
@*hihi*@

<table>
    <thead>
        <tr>
            <th>IDSP</th>
            <th>Tên sản phẩm</th>
            <th>Giá</th>
            <th>Hình Ảnh</th>
            <th>Ngày Tạo</th>
            <th>Mô tả</th>
            <th>Giảm Giá</th>
            <th>IDVC</th>
            <th>Danh Mục</th>
            <th>Hành động</th>

        </tr>
        @foreach (var a in ViewBag.list)
        {
            <tr>
                <td>@a[0]</td>
                <td>@a[1]</td>
                <td>@a[2]</td>
                <td><img src="~/Content/Hinh/@a[3]" alt="Hình ảnh sản phẩm" width="50" height="50" /></td>
                <td>@a[4]</td>
                <td>@a[5]</td>
                <td>@a[6]</td>
                <td>@a[7]</td>
                <td>@a[8]</td>
                
                
                    @*Chỉnh phần này để chứa các nút sửa, xóa*@
                <td>
                    <a href="@Url.Action("ChinhSuaSP", "SanPham", new { id = a[0] })" class="btn-edit">Sửa</a>
                    <button class="btn-delete" data-id="@a[0]">Xóa</button>
                </td>


                
            </tr>
        }

    </thead>

    <tbody>

        @*Add more rows as needed*@
    </tbody>
</table>

<script>
    // Sự kiện khi nhấn nút "Xóa"
    document.querySelectorAll('.btn-delete').forEach(button => {
        button.addEventListener('click', function () {
            const productId = this.getAttribute('data-id');
            if (confirm('Bạn có chắc chắn muốn xóa sản phẩm này không?')) {
                // Gửi yêu cầu xóa đến server (cần route tương ứng phía backend)
                fetch(`/SanPham/XoaSanPham/${productId}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                    .then(response => {
                        if (response.ok) {
                            alert('Sản phẩm đã được xóa thành công.');
                            location.reload(); // Tải lại trang sau khi xóa thành công
                        } else {
                            alert('Xóa sản phẩm thất bại.');
                        }
                    })
                    .catch(error => {
                        console.error('Lỗi:', error);
                    });
            }
        });
    });

    // Sự kiện khi nhấn nút "Sửa"
    document.querySelectorAll('.btn-edit').forEach(button => {
        button.addEventListener('click', function () {
            const productId = this.getAttribute('data-id');
            // Điều hướng tới trang sửa sản phẩm
            window.location.href = `/SanPham/ChinhSuaSP/${productId}`;
        });
    });
</script>