@{
    ViewBag.Title = "Chỉnh Sửa Sản Phẩm";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="main-content">
    <div class="form-container">
        <h2 class="form-title">Chỉnh Sửa Sản Phẩm</h2>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @Html.ValidationSummary(false)
            </div>
        }

        <form action="~/SanPham/ChinhSuaSP" method="post" enctype="multipart/form-data" class="product-form">
            <input type="hidden" name="IDSP" value="@ViewBag.IDSP" />

            <div class="form-group">
                <label for="TenSP">Tên Sản Phẩm *</label>
                <input type="text" id="TenSP" name="TenSP" class="form-control" required
                       placeholder="Nhập tên sản phẩm" value="@ViewBag.TenSP" />
            </div>

            <div class="form-group">
                <label for="Gia">Giá *</label>
                <input type="number" id="Gia" name="Gia" class="form-control" required
                       min="0" step="1000" value="@ViewBag.Gia" />
            </div>

            <div class="form-group">
                <label for="GiamGia">Giảm Giá (%)</label>
                <input type="number" id="GiamGia" name="GiamGia" class="form-control"
                       min="0" max="100" value="@(ViewBag.GiamGia ?? 0)" />
            </div>

            <div class="form-group">
                <label for="MoTa">Mô Tả</label>
                <textarea id="MoTa" name="MoTa" class="form-control" rows="4">@ViewBag.MoTa</textarea>
            </div>

            <div class="form-group">
                <label for="IDDM">Danh Mục *</label>
                <select id="IDDM" name="IDDM" class="form-control" required>
                    <option value="">-- Chọn danh mục --</option>
                    <option value="1" @(ViewBag.IDDM == 1 ? "selected" : "")>Trà</option>
                    <option value="2" @(ViewBag.IDDM == 2 ? "selected" : "")>Café</option>
                    <option value="3" @(ViewBag.IDDM == 3 ? "selected" : "")>Nước ép</option>
                </select>
            </div>

            <div class="form-group">
                <label for="IDVC">IDVC *</label>
                <select id="IDVC" name="IDVC" class="form-control" required>
                    <option value="">-- Chọn voucher --</option>
                    <option value="1" @(ViewBag.IDVC == 1 ? "selected" : "")>Không áp dụng</option>
                    <option value="2" @(ViewBag.IDVC == 2 ? "selected" : "")>Voucher 1</option>
                    <option value="3" @(ViewBag.IDVC == 3 ? "selected" : "")>Voucher 2</option>
                    <option value="4" @(ViewBag.IDVC == 4 ? "selected" : "")>Voucher 3</option>
                    <!-- Thêm các voucher khác nếu cần -->
                </select>
            </div>

            <div class="form-group">
                <label for="NgayTao">Ngày Tạo *</label>
                <input type="date" id="NgayTao" name="NgayTao" class="form-control" required
                       value="@(ViewBag.NgayTao != null ? ((DateTime)ViewBag.NgayTao).ToString("yyyy-MM-dd") : DateTime.Now.ToString("yyyy-MM-dd"))" />
            </div>

            <div class="center">
                <div class="form-group form">
                    <span class="form-title">Hình Ảnh</span>
                    <label for="HinhAnh" class="drop-container">
                        <span class="drop-title">Kéo thả file vào đây</span>
                        hoặc
                        <input type="file" id="HinhAnh" name="HinhAnh" accept="image/*">
                    </label>
                    <div id="image-preview" class="image-preview">
                        @if (!string.IsNullOrEmpty(ViewBag.HinhAnh))
                        {
                            <img src="~/Content/Hinh/@ViewBag.HinhAnh" alt="Hình ảnh hiện tại" style="max-width: 200px; max-height: 200px;" />
                        }
                    </div>
                    <input type="hidden" name="existingImage" value="@ViewBag.HinhAnh" />
                </div>
            </div>

            <div class="form-actions center">
                <button type="submit" class="btn btn-primary">Cập Nhật Sản Phẩm</button>
                <a href="@Url.Action("QLSanPham", "SanPham")" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>

<script>
    // Preview hình ảnh trước khi upload
    document.getElementById('HinhAnh').addEventListener('change', function (e) {
        const preview = document.getElementById('image-preview');
        preview.innerHTML = '';

        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function (e) {
                const img = document.createElement('img');
                img.src = e.target.result;
                img.style.maxWidth = '200px';
                img.style.maxHeight = '200px';
                preview.appendChild(img);
            }
            reader.readAsDataURL(file);
        }
    });
</script>